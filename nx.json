{
  "tasksRunnerOptions": {
    "default": {
      "options": {
        "canTrackAnalytics": true,
        "maxParallel": 6
      }
    }
  },
  "parallel": 1,
  "defaultProject": "app-dh",
  "generators": {
    "@nx/angular:application": {
      "style": "scss",
      "linter": "eslint",
      "unitTestRunner": "vitest-analog",
      "e2eTestRunner": "playwright"
    },
    "@nx/angular:library": {
      "linter": "eslint",
      "unitTestRunner": "vitest-analog"
    },
    "@schematics/angular:component": {
      "style": "scss",
      "type": "component"
    },
    "@nx/angular:component": {
      "style": "scss",
      "type": "component"
    },
    "@nx/angular": {
      "application": {
        "linter": "eslint"
      },
      "library": {
        "linter": "eslint"
      },
      "storybook-configuration": {
        "linter": "eslint"
      },
      "directive": {
        "type": "directive"
      },
      "service": {
        "type": "service"
      },
      "scam": {
        "type": "component"
      },
      "scam-directive": {
        "type": "directive"
      },
      "guard": {
        "typeSeparator": "."
      },
      "interceptor": {
        "typeSeparator": "."
      },
      "module": {
        "typeSeparator": "."
      },
      "pipe": {
        "typeSeparator": "."
      },
      "resolver": {
        "typeSeparator": "."
      }
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  },
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "cache": true
    },
    "e2e": {
      "inputs": ["default", "^production"],
      "cache": true
    },
    "test": {
      "dependsOn": [
        {
          "projects": ["dh-shared-domain"],
          "target": "generate"
        }
      ],
      "inputs": ["default", "^production"],
      "cache": true
    },
    "build-storybook": {
      "inputs": [
        "default",
        "^production",
        "{projectRoot}/.storybook/**/*",
        "{projectRoot}/tsconfig.storybook.json"
      ],
      "cache": true
    },
    "lint": {
      "dependsOn": [
        {
          "projects": ["dh-shared-domain"],
          "target": "generate"
        }
      ],
      "inputs": ["default", "{workspaceRoot}/.eslintrc.json"],
      "cache": true
    }
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": [
      "{workspaceRoot}/tools/plugins/implicit-libs.ts",
      "{workspaceRoot}/libs/dh/vite.config.mts",
      "{workspaceRoot}/libs/gf/vite.config.mts"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/vite.config.mts",
      "!{projectRoot}/vitest.config.mts",
      "!{projectRoot}/.eslintrc.json",
      "!{projectRoot}/.storybook/**/*",
      "!{projectRoot}/**/*.stories.@(js|jsx|ts|tsx|mdx)",
      "!{projectRoot}/playwright.config.[jt]s",
      "!{projectRoot}/tsconfig.storybook.json",
      "!{projectRoot}/src/test-setup.[jt]s",
      "!{projectRoot}/tests/test-setup.[jt]s",
      "!{projectRoot}/**/*.Tests/**/*",
      "!{projectRoot}/**/bin/**/*",
      "!{projectRoot}/**/obj/**/*"
    ]
  },
  "defaultBase": "main",
  "nxCloudId": "6124f33c6b561869a0db14ff",
  "plugins": [
    "./tools/plugins/implicit-libs.ts",
    {
      "plugin": "@nx/eslint/plugin",
      "exclude": ["libs/watt/package/**/*"],
      "options": {
        "targetName": "lint"
      }
    },
    {
      "plugin": "@nx/vite/plugin",
      "exclude": ["libs/dh/vite.config.mts", "libs/gf/vite.config.mts"],
      "options": {
        "testTargetName": "test"
      }
    },
    {
      "plugin": "@nx/playwright/plugin",
      "options": {
        "targetName": "e2e"
      }
    },
    {
      "plugin": "@nx/storybook/plugin",
      "options": {
        "serveStorybookTargetName": "storybook",
        "buildStorybookTargetName": "build-storybook"
      }
    },
    {
      "plugin": "@nx/dotnet",
      "options": {
        "build": {
          "outputs": [
            "{projectRoot}/bin",
            "{projectRoot}/obj",
            "{projectRoot}/bin/Debug/net10.0",
            "{projectRoot}/obj/Debug/net10.0/ref",
            "{workspaceRoot}/libs/dh/shared/data-access-graphql/schema.graphql"
          ]
        },
        "watch": {
          "targetName": "serve"
        },
        "restore": {
          "cache": false
        }
      }
    }
  ],
  "analytics": false
}
