{
  "name": "dh-globalization-domain",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "targets": {
    "generate": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["{workspaceRoot}/libs/**/src/i18n/*.json", "{projectRoot}/codegen.ts"],
      "outputs": [
        "{projectRoot}/src/generated/i18n/types.ts",
        "{projectRoot}/src/generated/i18n/providers.ts"
      ],
      "options": {
        "commands": ["bun libs/dh/globalization/domain/codegen.ts"]
      }
    }
  }
}
