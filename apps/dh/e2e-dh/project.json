{
  "name": "e2e-dh",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/dh/e2e-dh/src",
  "projectType": "application",
  "tags": ["product:dh", "type:e2e"],
  "implicitDependencies": ["app-dh"],
  "targets": {
    "e2e": {
      "dependsOn": ["^generate"],
      "configurations": {
        "ci": {
          "args": "--browser chrome --config excludeSpecPattern=**/*-healthchecks.cy.ts"
        },
        "health": {
          "args": "--browser chrome --spec **/*-healthchecks.cy.ts"
        },
        "dev": {
          "env": {
            "CYPRESS_webServerCommand": "bun nx run app-dh:serve:development"
          }
        },
        "production": {
          "env": {
            "CYPRESS_webServerCommand": "bun nx run app-dh:serve:production"
          }
        }
      }
    }
  }
}
