  "components": {
    "schemas": {
      "ActorType": {
        "type": "string",
        "description": "Application layer receiver type",
        "enum": [
          "EnergySupplier",
          "Energinet",
          "GridAccessProvider"
        ]
      },
      "AddConversationMessageRequest": {
        "type": "object",
        "required": [
          "conversationId",
          "content",
          "anonymous"
        ],
        "properties": {
          "conversationId": {
            "type": "string",
            "description": "Conversation subject.",
            "format": "uuid"
          },
          "content": {
            "type": "string",
            "description": "The message content, thus the body itself.\nCan contain at most 5000 characters and should not be empty."
          },
          "anonymous": {
            "type": "boolean",
            "description": "Specifies whether the message is anonymous with respect to the Sender information."
          }
        }
      },
      "CloseConversationRequest": {
        "type": "object",
        "required": [
          "conversationId"
        ],
        "properties": {
          "conversationId": {
            "type": "string",
            "description": "Conversation subject.",
            "format": "uuid"
          }
        }
      },
      "ConversationDto": {
        "type": "object",
        "description": "Conversation",
        "required": [
          "meteringPointIdentification",
          "displayId",
          "internalNote",
          "subject",
          "closed",
          "messages",
          "partOfConversations"
        ],
        "properties": {
          "meteringPointIdentification": {
            "type": "string",
            "description": "MeteringPoint identification"
          },
          "displayId": {
            "description": "Display Id of the conversation",
            "format": "int32",
            "pattern": "^-?(?:0|[1-9]\\d*)$"
          },
          "internalNote": {
            "type": "string",
            "description": "Internal note from the creator",
            "nullable": true
          },
          "subject": {
            "$ref": "#/components/schemas/ConversationSubject"
          },
          "closed": {
            "type": "boolean",
            "description": "true for conversations that are closed. false otherwise."
          },
          "messages": {
            "type": "array",
            "description": "Messages associated with a conversation",
            "items": {
              "$ref": "#/components/schemas/ConversationMessageDto"
            }
          },
          "partOfConversations": {
            "type": "boolean",
            "description": "Indicates id you are part of this conversation.\nEnerginet can see conversations they are not part of."
          }
        }
      },
      "ConversationInfoDto": {
        "type": "object",
        "description": "Conversation info",
        "required": [
          "conversationId",
          "meteringPointIdentification",
          "read",
          "subject",
          "displayId",
          "closed",
          "lastUpdated"
        ],
        "properties": {
          "conversationId": {
            "type": "string",
            "description": "Conversation id",
            "format": "uuid"
          },
          "meteringPointIdentification": {
            "type": "string",
            "description": "MeteringPoint Identification"
          },
          "read": {
            "type": "boolean",
            "description": "Specifies whether the conversation has been read or not"
          },
          "subject": {
            "$ref": "#/components/schemas/ConversationSubject"
          },
          "displayId": {
            "description": "Display id of the conversation",
            "format": "int32",
            "pattern": "^-?(?:0|[1-9]\\d*)$"
          },
          "closed": {
            "type": "boolean",
            "description": "Conversation is closed or not"
          },
          "lastUpdated": {
            "type": "string",
            "description": "Last updated time of the conversation",
            "format": "date-time"
          }
        }
      },
      "ConversationMessageDto": {
        "type": "object",
        "description": "Conversation message",
        "required": [
          "userId",
          "actorNumber",
          "senderType",
          "messageType",
          "createdTime",
          "anonymous"
        ],
        "properties": {
          "userId": {
            "type": "string",
            "description": "Sender user id",
            "nullable": true
          },
          "actorNumber": {
            "type": "string",
            "description": "Sendor actor number",
            "nullable": true
          },
          "senderType": {
            "$ref": "#/components/schemas/ActorType"
          },
          "messageType": {
            "$ref": "#/components/schemas/MessageType"
          },
          "createdTime": {
            "type": "string",
            "description": "Created time",
            "format": "date-time"
          },
          "anonymous": {
            "type": "boolean"
          },
          "userMessage": {
            "oneOf": [
              {
                "nullable": true
              },
              {
                "$ref": "#/components/schemas/UserMessageDto"
              }
            ]
          },
          "electricalHeatingMessage": {
            "oneOf": [
              {
                "nullable": true
              },
              {
                "$ref": "#/components/schemas/EleectricalHeatingMessageDto"
              }
            ]
          }
        }
      },
      "ConversationsDto": {
        "type": "object",
        "description": "Conversations",
        "required": [
          "conversations"
        ],
        "properties": {
          "conversations": {
            "type": "array",
            "description": "List of Conversations",
            "items": {
              "$ref": "#/components/schemas/ConversationInfoDto"
            }
          }
        }
      },
      "ConversationSubject": {
        "type": "string",
        "description": "Application layer conversation subject",
        "enum": [
          "QuestionForEnerginet",
          "InterruptionReconnection",
          "ElectricalHeating",
          "WrongfulMoveOrSupplierChange",
          "CustomerMasterData",
          "MeasurementData",
          "MeasurementPointMasterData",
          "PriceLinking"
        ]
      },
      "ElectricityHeatingMessagePeriodDto": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "properties": {
          "from": {
            "type": "string",
            "format": "date-time"
          },
          "to": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "EleectricalHeatingMessageDto": {
        "type": "object",
        "required": [
          "customerName",
          "supplierPeriods",
          "isElectricalHeatingActive",
          "electricalHeatingFrom"
        ],
        "properties": {
          "customerName": {
            "type": "string",
            "nullable": true
          },
          "supplierPeriods": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ElectricityHeatingMessagePeriodDto"
            }
          },
          "isElectricalHeatingActive": {
            "type": "boolean"
          },
          "electricalHeatingFrom": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "MarkConversationReadRequest": {
        "type": "object",
        "required": [
          "conversationId"
        ],
        "properties": {
          "conversationId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "MarkConversationUnreadRequest": {
        "type": "object",
        "required": [
          "conversationId"
        ],
        "properties": {
          "conversationId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "MessageType": {
        "type": "string",
        "description": "Message type",
        "enum": [
          "UserMessage",
          "ClosingMessage",
          "ElectricalHeatingInformation"
        ]
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "format": "int32",
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "StartConversationRequest": {
        "type": "object",
        "required": [
          "subject",
          "senderActorType",
          "receiverActorType",
          "meteringPointIdentification",
          "content",
          "anonymous"
        ],
        "properties": {
          "subject": {
            "$ref": "#/components/schemas/ConversationSubject"
          },
          "senderActorType": {
            "$ref": "#/components/schemas/ActorType"
          },
          "receiverActorType": {
            "$ref": "#/components/schemas/ActorType"
          },
          "meteringPointIdentification": {
            "type": "string",
            "description": "MeteringPointIdentification\n18 digits GSRN number consisting of digits only."
          },
          "internalNote": {
            "type": "string",
            "description": "Optional Internal note from the Organization, that created the Conversation.\nCan contain at most 80 characters and will be assumed empty, if not specified",
            "nullable": true
          },
          "content": {
            "type": "string",
            "description": "The message content, thus the body itself.\nCan contain at most 5000 characters and should not be empty."
          },
          "anonymous": {
            "type": "boolean",
            "description": "Specifies whether the message is anonymous with respect to the Sender information."
          }
        }
      },
      "StartConversationResponse": {
        "type": "object",
        "description": "Response for the request for starting a conversation",
        "required": [
          "conversationId"
        ],
        "properties": {
          "conversationId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "StartElectricalHeatingConversationRequest": {
        "type": "object",
        "required": [
          "meteringPointIdentification",
          "content",
          "anonymous",
          "electricalHeatingFrom",
          "electricalHeatingReductionPeriodFrom",
          "electricalHeatingReductionPeriodTo"
        ],
        "properties": {
          "meteringPointIdentification": {
            "type": "string"
          },
          "internalNote": {
            "type": "string",
            "nullable": true
          },
          "content": {
            "type": "string"
          },
          "anonymous": {
            "type": "boolean"
          },
          "electricalHeatingFrom": {
            "type": "string",
            "format": "date-time"
          },
          "electricalHeatingReductionPeriodFrom": {
            "type": "string",
            "format": "date-time"
          },
          "electricalHeatingReductionPeriodTo": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "StartElectricalHeatingConversationResponse": {
        "type": "object",
        "description": "Response for the request for starting a conversation",
        "required": [
          "conversationId"
        ],
        "properties": {
          "conversationId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "TestActorRetrievalResult": {
        "type": "object",
        "properties": {
          "energySupplierActorNumber": {
            "type": "string",
            "nullable": true
          },
          "gridAccesProviderActorNumber": {
            "type": "string",
            "nullable": true
          },
          "energySupplierExceptionMessage": {
            "type": "string",
            "nullable": true
          },
          "gridAccessproviderExceptionMessage": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "UpdateInternalNoteRequest": {
        "type": "object",
        "required": [
          "conversationId",
          "internalNote"
        ],
        "properties": {
          "conversationId": {
            "type": "string",
            "description": "Conversation subject.",
            "format": "uuid"
          },
          "internalNote": {
            "type": "string",
            "description": "Optional Internal note from the active participant\nCan contain at most 80 characters and will be assumed empty, if not specified",
            "nullable": true
          }
        }
      },
      "UserMessageDto": {
        "type": "object",
        "required": [
          "content"
        ],
        "properties": {
          "content": {
            "type": "string",
            "description": "Message content"
          }
        }
      }
    }
