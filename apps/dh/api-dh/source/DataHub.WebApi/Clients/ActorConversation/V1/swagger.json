    "/api/GetConversations": {
      "get": {
        "tags": [
          "GetAllConversations, GetConversationsForMeteringPoint"
        ],
        "summary": "Get all conversations or just conversations for a MeteringPoint, provided that query parameter 'meteringpointidentification' is supplied.\nThe result can be further narrowed by either searching or filtering or both.\n- Search\n  - Provides with support for searching into DisplayId and InternalNote for the logged in actor\n  - the search value is supplied as querystring 'searchValue'\n- Filtering\n  - The list can further be narrowed down via filters.\n  - Provides with supports for filtering myConversations, unread, opened, closed and subjects.\n  - Filters are supplied as querystring, ex. myconversations=true to get my conversations only.",
        "description": "Get all conversations across all meteringpoints or for a single MeteringPoint, provided that query parameter 'meteringpointidentification' is supplied",
        "operationId": "GetConversations",
        "parameters": [
          {
            "name": "meteringPointIdentification",
            "in": "query",
            "description": "GSRN consists of 18 digits supplied as querystring by name 'meteringPointIdentification'. Null to retrieve across all meteringpoints.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "searchValue",
            "in": "query",
            "description": "Search string supplied as querystring by name 'searchValue' to be searched for into DisplayId and InternalNote for the logged in actor.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "myConversations",
            "in": "query",
            "description": "Filter for only my conversations, thus participated either as sender, replied a message, closed the conversation. Passed as querystring of same name, ex. myConversations=true .",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "unread",
            "in": "query",
            "description": "Filter for only unread conversations. Passed as querystring of same name, ex. unread=true.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "opened",
            "in": "query",
            "description": "Filter for only opened or active conversations. Passed as querystring of same name, ex. opened=true.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "closed",
            "in": "query",
            "description": "Filter for only closed conversations. Passed as querystring of same name, ex. closed=true.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "subjects",
            "in": "query",
            "description": "Filter for only listed Conversationsubjects. passed as querystring of same name. ex subject=QuestionForEnerginet&amp;subjects=ElectricalHeating",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/ConversationSubject"
              }
            }
          },
          {
            "name": "UserId",
            "in": "header",
            "schema": {
              "type": "string",
              "default": "56d5b1f0-2eee-4b2e-b1e9-b711916c4796"
            }
          },
          {
            "name": "ActorNumber",
            "in": "header",
            "schema": {
              "type": "string",
              "default": "1234567891234"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationsDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationsDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationsDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
